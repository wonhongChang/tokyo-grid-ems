# OpenAI API
# Use a project-scoped variable name so Codex/OpenAI tooling does not treat this
# workspace .env file as a provider credential source.
TOKYO_GRID_EMS_OPENAI_API_KEY=your_openai_api_key_here
OPENAI_DAILY_REPORT_MODEL=gpt-4o-mini
OPENAI_DAILY_REPORT_LOCALIZATION_MODEL=gpt-4o-mini
OPENAI_DAILY_REPORT_TIMEOUT_SECONDS=90
OPENAI_DAILY_REPORT_LOCALIZATION_TIMEOUT_SECONDS=180
OPENAI_DAILY_REPORT_HTTP_ATTEMPTS=2
OPENAI_DAILY_REPORT_RETRY_BASE_SECONDS=2
OPENAI_DAILY_REPORT_LOCALES=ko,en,ja
OPENAI_DAILY_REPORT_MAX_CALLS_PER_RUN=2
OPENAI_DAILY_REPORT_LATEST_ONLY=1
